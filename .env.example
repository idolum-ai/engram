TELEGRAM_BOT_TOKEN=
TELEGRAM_API_BASE=https://api.telegram.org
TELEGRAM_ALLOWED_USER_ID=
TELEGRAM_CHAT_ID=
TELEGRAM_POLL_TIMEOUT_SECONDS=50

# Select one conversational guide provider. Only the selected provider's
# credential is used. A guide is required for guide startup and optional in
# snapshot mode for the voice button and runtime switching to guide.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.6-luna
# Voice replies default to a durable local attachment path. Select transcribe
# explicitly to send audio to OpenAI; this requires OPENAI_API_KEY.
VOICE_INPUT_MODE=path
OPENAI_TRANSCRIPTION_MODEL=gpt-4o-transcribe

ENGRAM_HOME=~/.engram
ENGRAM_WORKDIR=~
ENGRAM_TMUX_SESSION=
# Optional local regex cues. Enabling this stores only hashes for first-time
# observations; repeated candidates and explicitly approved cues may retain
# their redacted prompt and regex under ENGRAM_HOME.
ENGRAM_CUES=off
# Initial/fallback mode. A successful /mode choice is persisted in state.
ENGRAM_ANCHOR_MODE=guide
# Required for snapshot startup; optional in guide mode for the image button
# and runtime switching to snapshot. Leave empty for browser auto-detection.
# macOS auto-detection accepts dedicated headless executables only; set an
# explicit path to opt into a desktop Chromium application.
ENGRAM_SNAPSHOT_BROWSER=
ENGRAM_SNAPSHOT_THEME=terminal
# Optional trusted local command. Its one-line stdout is shown in image footers.
# Example: df -kP . | awk 'END {printf "disk %.1fG free\n", $4 / 1048576}'
ENGRAM_SNAPSHOT_STATUS_COMMAND=
ENGRAM_ATTACHMENT_SOFT_MAX_BYTES=16777216
